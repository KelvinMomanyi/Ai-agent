<!-- Modal Backdrop -->
<div id="chatbot-backdrop" class="cb-backdrop"></div>

<!-- Modal / Popup Container -->
<div id="chatbot-messages"
     class="cb-modal cb-type-{{ block.settings.popup_type }} cb-pos-{{ block.settings.popup_position }} cb-anim-{{ block.settings.animation_style }} {% if block.settings.enable_glassmorphism %}cb-glass{% endif %}"
     style="display: none;">

  <button onclick="closeChatbotModal()" class="cb-close-btn" aria-label="Close">
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>

  <div class="cb-flex-container">
    <div class="cb-image-section">
      <img id="chatbot-image" src="" alt="" />
    </div>
    <div class="cb-info-section">
      <div id="cb-discount-badge" class="cb-discount-badge" style="display: none;"></div>
      <div id="cb-gamification-msg" class="cb-gamification-msg" style="display: none;"></div>
      <h3 id="chatbot-title"></h3>
      <div class="cb-price-row">
        <span class="cb-currency" id="chatbot-currency">{{ shop.currency }}</span>
        <span class="cb-price-value" id="chatbot-price"></span>
      </div>
      <p id="chatbot-text" class="cb-text"></p>
      <form method="POST" action="/cart/add" onsubmit="handleSubmit(event, this)">
        <input type="hidden" name="id" id="upsell-variant-id" value="" />
        <input type="hidden" name="quantity" value="1" />
        <button type="submit" class="cb-add-to-cart-btn">Add to Cart</button>
      </form>
    </div>
  </div>
</div>

<!-- Inline Upsell Container -->
<div id="cb-inline-display" class="cb-inline-container {% if block.settings.enable_glassmorphism %}cb-glass{% endif %}">
  <div class="cb-flex-container">
    <div class="cb-image-section">
      <img id="cb-inline-image" src="" alt="">
    </div>
    <div class="cb-info-section">
      <div id="cb-inline-discount-badge" class="cb-discount-badge" style="display: none;"></div>
      <div id="cb-inline-gamification-msg" class="cb-gamification-msg" style="display: none;"></div>
      <h3 id="cb-inline-title"></h3>
      <div class="cb-price-row">
        <span class="cb-currency" id="cb-inline-currency"></span>
        <span class="cb-price-value" id="cb-inline-price"></span>
      </div>
      <p id="cb-inline-text" class="cb-text"></p>
      <form onsubmit="handleSubmit(event, this)" action="/cart/add" method="post">
        <input type="hidden" name="id" id="cb-inline-variant-id" value="">
        <input type="hidden" name="quantity" value="1" />
        <button type="submit" class="cb-add-to-cart-btn">Add to Cart</button>
      </form>
    </div>
  </div>
</div>

<style>
/* ===================================================================
   AI AGENT UPSELL — DESIGN SYSTEM
   Professionally balanced & theme-integrated. z-index: 2147483647
   =================================================================== */

/* ---------- SCOPED RESET ---------- */
.cb-modal, .cb-modal *,
.cb-inline-container, .cb-inline-container * {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  font-family: inherit; /* Use theme typography */
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* ---------- BACKDROP ---------- */
.cb-backdrop {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 2147483646;
  backdrop-filter: blur(2px);
  -webkit-backdrop-filter: blur(2px);
}

/* ---------- BASE MODAL ---------- */
.cb-modal {
  display: none;
  position: fixed;
  z-index: 2147483647;
  width: 92%;
  max-width: 540px;
  background: {{ block.settings.modal_background_color | default: '#ffffff' }};
  border-radius: {{ block.settings.modal_border_radius | default: 12 }}px;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
  overflow: hidden;
  border: 1px solid rgba(0,0,0,0.05);
}

/* ---------- GLASS EFFECT ---------- */
.cb-glass {
  background: rgba(255, 255, 255, 0.8) !important;
  backdrop-filter: blur(12px) saturate(160%);
  -webkit-backdrop-filter: blur(12px) saturate(160%);
  border: 1px solid rgba(255, 255, 255, 0.4);
}

/* ---------- POSITIONS ---------- */
.cb-pos-center { top: 50%; left: 50%; transform: translate(-50%, -50%); }
.cb-pos-bottom_left { bottom: 20px; left: 20px; transform: none; }
.cb-pos-bottom_right { bottom: 20px; right: 20px; transform: none; }
.cb-pos-top_center { top: 20px; left: 50%; transform: translateX(-50%); }

/* ---------- CLOSE BUTTON ---------- */
.cb-close-btn {
  position: absolute;
  top: 10px;
  right: 10px;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  border: none;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.04);
  color: #666;
  cursor: pointer;
  transition: background 0.2s;
}
.cb-close-btn:hover { background: rgba(0, 0, 0, 0.08); color: #000; }

/* ---------- FLEX CONTAINER ---------- */
.cb-flex-container { display: flex; flex-direction: row; min-height: 200px; }

/* ---------- IMAGE SECTION ---------- */
.cb-image-section {
  flex: 0 0 40%;
  background: {{ block.settings.image_section_Background_color | default: '#f7f7f7' }};
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px;
}
.cb-image-section img {
  width: 100%;
  height: auto;
  max-height: 240px;
  object-fit: contain;
  border-radius: 6px;
}

/* ---------- INFO SECTION ---------- */
.cb-info-section {
  flex: 1;
  padding: 24px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 8px;
  max-height: 80vh;
  overflow-y: auto;
}
.cb-info-section h3 {
  font-size: {{ block.settings.modal_title_fontSize | default: 18 }}px;
  font-weight: 600;
  color: {{ block.settings.modal_title_color | default: '#000' }};
}

/* ---------- PRICE ---------- */
.cb-price-row {
  display: flex;
  align-items: baseline;
  gap: 4px;
  font-weight: 600;
  font-size: {{ block.settings.modal_price_fontSize | default: 16 }}px;
  color: {{ block.settings.modal_price_color | default: '#000' }};
}
.cb-currency { font-size: 0.8em; opacity: 0.5; }

/* ---------- DESCRIPTION ---------- */
.cb-text {
  font-size: {{ block.settings.modal_text_fontSize | default: 14 }}px;
  color: {{ block.settings.modal_text_color | default: '#444' }};
  line-height: 1.5;
}

/* ---------- BUTTON ---------- */
.cb-add-to-cart-btn {
  width: 100%;
  padding: 12px;
  margin-top: 4px;
  border: none;
  border-radius: 8px;
  background: {{ block.settings.modal_button_color | default: '#000' }};
  color: {{ block.settings.modal_Button_text_color | default: '#fff' }};
  font-weight: 600;
  cursor: pointer;
  transition: opacity 0.2s;
}
.cb-add-to-cart-btn:hover { opacity: 0.9; }

/* ---------- DISCOUNT BADGE ---------- */
.cb-discount-badge {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 4px;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #fff;
  background: #e63946; /* Professional solid accent */
  margin-bottom: 4px;
}

/* ---------- GAMIFICATION MSG ---------- */
.cb-gamification-msg {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 4px;
  font-size: 0.75rem;
  font-weight: 600;
  color: #155724;
  background: #d4edda;
  border: 1px solid #c3e6cb;
  margin-bottom: 8px;
}

/* =================================================================
   LAYOUT VARIANTS
   ================================================================= */

/* Toast - Balanced proportions */
.cb-type-toast { max-width: 380px; }
.cb-type-toast .cb-image-section { flex: 0 0 90px; }
.cb-type-toast .cb-image-section img { max-height: 100px; }
.cb-type-toast .cb-info-section { padding: 16px; gap: 4px; }
.cb-type-toast h3 { font-size: 1rem; }
.cb-type-toast .cb-text { font-size: 0.85rem; }

/* Floating Card - Stacked */
.cb-type-floating { max-width: 300px; }
.cb-type-floating .cb-flex-container { flex-direction: column; }
.cb-type-floating .cb-image-section { flex: none; height: 140px; padding: 10px 10px 0; background: transparent; }
.cb-type-floating .cb-image-section img { height: 100%; object-fit: cover; }
.cb-type-floating .cb-info-section { padding: 12px 16px 16px; }

/* =================================================================
   ANIMATIONS
   ================================================================= */
.cb-anim-fade   { animation: cb-fadeIn 0.3s ease both; }
.cb-anim-slide_up { animation: cb-slideUp 0.4s ease-out both; }
.cb-anim-bounce { animation: cb-bounceIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) both; }

@keyframes cb-fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes cb-slideUp {
  from { opacity: 0; transform: translate(-50%,-45%); }
  to   { opacity: 1; transform: translate(-50%,-50%); }
}
.cb-pos-bottom_left.cb-anim-slide_up,
.cb-pos-bottom_right.cb-anim-slide_up { animation-name: cb-slideUpCorner; }
@keyframes cb-slideUpCorner { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

@keyframes cb-bounceIn {
  from { opacity: 0; transform: translate(-50%,-50%) scale(0.8); }
  to   { opacity: 1; transform: translate(-50%,-50%) scale(1); }
}

/* =================================================================
   INLINE
   ================================================================= */
.cb-inline-container {
  display: none;
  max-width: 100%;
  margin: 15px 0;
  border-radius: {{ block.settings.modal_border_radius | default: 8 }}px;
  background: {{ block.settings.modal_background_color | default: '#ffffff' }};
  border: 1px solid rgba(0,0,0,0.08);
  overflow: hidden;
}

/* =================================================================
   RESPONSIVE
   ================================================================= */
@media (max-width: 600px) {
  .cb-modal { width: calc(100% - 20px); max-width: none; border-radius: 8px; }
  .cb-pos-center { top: auto; bottom: 10px; left: 10px; right: 10px; transform: none; }
  .cb-pos-bottom_left, .cb-pos-bottom_right, .cb-pos-top_center { left: 10px; right: 10px; bottom: 10px; top: auto; width: auto; transform: none; }
  
  .cb-flex-container { flex-direction: column !important; }
  .cb-image-section { flex: none !important; height: 160px; }
  .cb-info-section { padding: 16px !important; }

  .cb-type-toast .cb-flex-container { flex-direction: row !important; }
  .cb-type-toast .cb-image-section { flex: 0 0 80px !important; height: auto !important; }
}
</style>



