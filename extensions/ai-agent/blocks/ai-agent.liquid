<div
  id="ai-revenue-engine-{{ block.id }}"
  class="are-root"
  data-block-id="{{ block.id }}"
>
  <div id="are-backdrop-{{ block.id }}" class="are-backdrop" hidden></div>

  <section
    id="are-offer-{{ block.id }}"
    class="are-offer"
    aria-live="polite"
    hidden
  >
    <button
      type="button"
      id="are-close-{{ block.id }}"
      class="are-close"
      aria-label="Close offer"
    >
      &times;
    </button>

    <div class="are-media" id="are-media-{{ block.id }}"></div>

    <div class="are-content">
      <div class="are-meta">
        <span id="are-mode-{{ block.id }}" class="are-pill">AI Revenue Engine</span>
        <span id="are-experiment-{{ block.id }}" class="are-pill are-pill-muted">Testing</span>
      </div>

      <h3 id="are-title-{{ block.id }}" class="are-title"></h3>

      <div class="are-price-row">
        <span id="are-currency-{{ block.id }}" class="are-currency">{{ shop.currency }}</span>
        <span id="are-price-{{ block.id }}" class="are-price"></span>
        <span id="are-compare-{{ block.id }}" class="are-compare"></span>
      </div>

      <p id="are-message-{{ block.id }}" class="are-message"></p>
      <ul id="are-items-{{ block.id }}" class="are-items"></ul>
      <p id="are-insight-{{ block.id }}" class="are-insight"></p>

      <form id="are-form-{{ block.id }}" class="are-form" action="/cart/add" method="post">
        <button type="submit" id="are-submit-{{ block.id }}" class="are-submit">
          Add revenue offer
        </button>
      </form>
    </div>
  </section>
</div>

<style>
  #ai-revenue-engine-{{ block.id }},
  #ai-revenue-engine-{{ block.id }} * {
    box-sizing: border-box;
  }

  #ai-revenue-engine-{{ block.id }} {
    font-family: inherit;
  }

  #ai-revenue-engine-{{ block.id }} .are-backdrop {
    position: fixed;
    inset: 0;
    z-index: 2147483640;
    background: rgba(17, 24, 39, 0.42);
  }

  #ai-revenue-engine-{{ block.id }} .are-offer {
    position: relative;
    width: 100%;
    max-width: 760px;
    margin: 16px 0;
    display: grid;
    grid-template-columns: minmax(140px, 0.42fr) minmax(0, 0.58fr);
    overflow: hidden;
    border: 1px solid rgba(17, 24, 39, 0.12);
    border-radius: {{ block.settings.modal_border_radius | default: 8 }}px;
    background: {{ block.settings.modal_background_color | default: '#ffffff' }};
    color: {{ block.settings.modal_title_color | default: '#111827' }};
    box-shadow: 0 12px 32px rgba(17, 24, 39, 0.12);
  }

  #ai-revenue-engine-{{ block.id }} .are-offer[hidden],
  #ai-revenue-engine-{{ block.id }} .are-backdrop[hidden] {
    display: none;
  }

  #ai-revenue-engine-{{ block.id }} .are-offer.are-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    z-index: 2147483641;
    transform: translate(-50%, -50%);
    width: min(760px, calc(100vw - 28px));
    margin: 0;
  }

  #ai-revenue-engine-{{ block.id }} .are-offer.are-slide {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 2147483641;
    width: min(520px, calc(100vw - 28px));
    margin: 0;
    grid-template-columns: 150px minmax(0, 1fr);
  }

  #ai-revenue-engine-{{ block.id }} .are-close {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 2;
    width: 28px;
    height: 28px;
    border: 0;
    border-radius: 999px;
    background: rgba(17, 24, 39, 0.08);
    color: #111827;
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
  }

  #ai-revenue-engine-{{ block.id }} .are-media {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    align-content: center;
    padding: 14px;
    background: {{ block.settings.image_section_Background_color | default: '#f3f4f6' }};
  }

  #ai-revenue-engine-{{ block.id }} .are-media.are-single {
    grid-template-columns: 1fr;
  }

  #ai-revenue-engine-{{ block.id }} .are-media img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    border-radius: 6px;
    background: #ffffff;
  }

  #ai-revenue-engine-{{ block.id }} .are-content {
    min-width: 0;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  #ai-revenue-engine-{{ block.id }} .are-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    padding-right: 26px;
  }

  #ai-revenue-engine-{{ block.id }} .are-pill {
    display: inline-flex;
    align-items: center;
    min-height: 22px;
    padding: 3px 8px;
    border-radius: 999px;
    background: {{ block.settings.modal_button_color | default: '#111827' }};
    color: {{ block.settings.modal_Button_text_color | default: '#ffffff' }};
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  #ai-revenue-engine-{{ block.id }} .are-pill-muted {
    background: rgba(17, 24, 39, 0.08);
    color: #374151;
  }

  #ai-revenue-engine-{{ block.id }} .are-title {
    margin: 0;
    font-size: {{ block.settings.modal_title_fontSize | default: 20 }}px;
    line-height: 1.2;
    color: {{ block.settings.modal_title_color | default: '#111827' }};
    letter-spacing: 0;
  }

  #ai-revenue-engine-{{ block.id }} .are-price-row {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 6px;
    color: {{ block.settings.modal_price_color | default: '#111827' }};
  }

  #ai-revenue-engine-{{ block.id }} .are-price {
    font-size: {{ block.settings.modal_price_fontSize | default: 18 }}px;
    font-weight: 700;
  }

  #ai-revenue-engine-{{ block.id }} .are-currency,
  #ai-revenue-engine-{{ block.id }} .are-compare {
    color: #6B7280;
    font-size: 13px;
  }

  #ai-revenue-engine-{{ block.id }} .are-compare {
    text-decoration: line-through;
  }

  #ai-revenue-engine-{{ block.id }} .are-message,
  #ai-revenue-engine-{{ block.id }} .are-insight {
    margin: 0;
    color: {{ block.settings.modal_text_color | default: '#374151' }};
    font-size: {{ block.settings.modal_text_fontSize | default: 14 }}px;
    line-height: 1.5;
  }

  #ai-revenue-engine-{{ block.id }} .are-insight {
    padding: 10px 12px;
    border-left: 3px solid {{ block.settings.modal_button_color | default: '#111827' }};
    background: rgba(17, 24, 39, 0.05);
    color: #374151;
  }

  #ai-revenue-engine-{{ block.id }} .are-items {
    display: grid;
    gap: 6px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #ai-revenue-engine-{{ block.id }} .are-items li {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    color: #374151;
    font-size: 13px;
  }

  #ai-revenue-engine-{{ block.id }} .are-submit {
    width: 100%;
    min-height: 44px;
    border: 0;
    border-radius: 6px;
    background: {{ block.settings.modal_button_color | default: '#111827' }};
    color: {{ block.settings.modal_Button_text_color | default: '#ffffff' }};
    cursor: pointer;
    font: inherit;
    font-weight: 700;
  }

  #ai-revenue-engine-{{ block.id }} .are-submit:disabled {
    cursor: wait;
    opacity: 0.7;
  }

  @media (max-width: 640px) {
    #ai-revenue-engine-{{ block.id }} .are-offer,
    #ai-revenue-engine-{{ block.id }} .are-offer.are-slide,
    #ai-revenue-engine-{{ block.id }} .are-offer.are-modal {
      grid-template-columns: 1fr;
      width: calc(100vw - 20px);
      max-width: none;
      left: 10px;
      right: 10px;
      bottom: 10px;
      top: auto;
      transform: none;
    }

    #ai-revenue-engine-{{ block.id }} .are-media {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      padding: 12px;
    }

    #ai-revenue-engine-{{ block.id }} .are-content {
      padding: 18px;
    }
  }
</style>

<script>
(() => {
  const blockId = "{{ block.id }}";
  const settings = {
    displayMode: "{{ block.settings.display_mode | default: 'autopilot' }}",
    smartDelay: Number({{ block.settings.smart_delay | default: 1 }}) * 1000,
    triggerOnLoad: {{ block.settings.trigger_on_load | default: true | json }},
    redirectToCheckout: {{ block.settings.redirect_to_checkout | default: false | json }},
    currency: "{{ shop.currency }}"
  };

  const root = document.getElementById(`ai-revenue-engine-${blockId}`);
  const offerEl = document.getElementById(`are-offer-${blockId}`);
  const backdropEl = document.getElementById(`are-backdrop-${blockId}`);
  const closeEl = document.getElementById(`are-close-${blockId}`);
  const formEl = document.getElementById(`are-form-${blockId}`);
  const submitEl = document.getElementById(`are-submit-${blockId}`);

  if (!root || !offerEl || window[`__are_${blockId}`]) return;
  window[`__are_${blockId}`] = true;

  let activeOffer = null;
  let activeBehavior = null;
  let currentDiscountCode = null;
  let inFlight = false;
  let lastCartSignature = "";

  recordViewedProduct();

  closeEl?.addEventListener("click", () => {
    hideOffer();
    if (activeOffer) {
      trackEvent("offer_dismissed", buildTrackingPayload(activeOffer, activeBehavior));
    }
  });

  backdropEl?.addEventListener("click", hideOffer);
  formEl?.addEventListener("submit", handleOfferSubmit);

  if (settings.triggerOnLoad) {
    window.setTimeout(() => requestRevenueOffer("page_load"), settings.smartDelay);
  }

  installCartHooks();

  async function requestRevenueOffer(trigger) {
    if (inFlight) return;
    inFlight = true;

    try {
      const cart = await fetchCart();
      if (!cart || !Array.isArray(cart.items)) return;

      const signature = getCartSignature(cart);
      if (trigger !== "page_load" && signature === lastCartSignature) return;
      lastCartSignature = signature;

      if (cart.item_count === 0 && getPageType() !== "product") return;

      const behaviorContext = collectBehaviorContext(cart);
      const response = await fetch("/apps/upsell", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json"
        },
        body: JSON.stringify({
          cartItems: cart.items,
          cartTotal: cart.total_price,
          currency: cart.currency,
          itemCount: cart.item_count,
          behaviorContext
        })
      });

      if (!response.ok) return;

      const data = await response.json();
      const offer = parseOffer(data.suggestion);
      if (!offer || !offer.id) return;

      activeBehavior = behaviorContext;
      renderOffer(offer, behaviorContext, cart);
    } catch (error) {
      console.warn("AI Revenue Engine skipped:", error);
    } finally {
      inFlight = false;
    }
  }

  function renderOffer(offer, behaviorContext, cart) {
    activeOffer = offer;
    currentDiscountCode = offer.discount?.code || null;

    const renderMode = resolveRenderMode(offer.placement);
    offerEl.classList.remove("are-modal", "are-slide", "are-inline");
    offerEl.classList.add(`are-${renderMode}`);
    backdropEl.hidden = renderMode !== "modal";

    setText("are-mode", offer.modeLabel || "AI Revenue Engine");
    setText("are-experiment", offer.experiment?.variant || "Adaptive offer");
    setText("are-title", offer.bundle?.title || offer.title || "Recommended offer");
    setText("are-message", offer.message || "");
    setText("are-insight", offer.insight || offer.autopilotAction || "");
    setText("are-currency", cart.currency || settings.currency);

    const price = offer.bundle?.discountedTotal || offer.price || "";
    const compare = offer.bundle?.subtotal && offer.bundle.subtotal !== price ? offer.bundle.subtotal : "";
    setText("are-price", price);
    setText("are-compare", compare);

    const items = getOfferItems(offer);
    renderMedia(items);
    renderItems(items);

    submitEl.textContent = offer.offerType === "bundle" ? "Add bundle to cart" : "Add to cart";
    offerEl.hidden = false;

    trackEvent("upsell_impression", buildTrackingPayload(offer, behaviorContext));
  }

  function renderMedia(items) {
    const media = document.getElementById(`are-media-${blockId}`);
    if (!media) return;

    media.classList.toggle("are-single", items.length === 1);
    media.innerHTML = items
      .slice(0, 4)
      .map((item) => `<img src="${escapeHtml(item.image || "")}" alt="${escapeHtml(item.title || "")}" loading="lazy">`)
      .join("");
  }

  function renderItems(items) {
    const list = document.getElementById(`are-items-${blockId}`);
    if (!list) return;

    list.innerHTML = items
      .map((item) => `<li><span>${escapeHtml(item.title || "")}</span><strong>${escapeHtml(item.price || "")}</strong></li>`)
      .join("");
  }

  async function handleOfferSubmit(event) {
    event.preventDefault();
    if (!activeOffer) return;

    const originalText = submitEl.textContent;
    submitEl.disabled = true;
    submitEl.textContent = "Adding...";

    try {
      if (currentDiscountCode) {
        await fetch(`/discount/${encodeURIComponent(currentDiscountCode)}`);
      }

      const items = getOfferItems(activeOffer).map((item) => ({
        id: toNumericVariantId(item.id),
        quantity: 1
      }));

      const response = await fetch("/cart/add.js", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json"
        },
        body: JSON.stringify(items.length > 1 ? { items } : items[0])
      });

      if (!response.ok) throw new Error("Unable to add offer to cart");

      const cartResponse = await response.json();
      trackEvent("upsell_add_to_cart", {
        ...buildTrackingPayload(activeOffer, activeBehavior),
        cartResponse
      });

      submitEl.textContent = "Added";

      window.setTimeout(() => {
        submitEl.disabled = false;
        submitEl.textContent = originalText;
        hideOffer();

        if (settings.redirectToCheckout) {
          window.location.href = "/checkout";
        }
      }, 800);
    } catch (error) {
      console.warn("Offer add failed:", error);
      submitEl.textContent = "Try again";
      window.setTimeout(() => {
        submitEl.disabled = false;
        submitEl.textContent = originalText;
      }, 1200);
    }
  }

  function installCartHooks() {
    const originalFetch = window.fetch;

    window.fetch = async function(...args) {
      const response = await originalFetch.apply(this, args);
      const url = getRequestUrl(args[0]);

      if (isCartAddUrl(url) && !url.includes("/apps/upsell")) {
        window.setTimeout(() => requestRevenueOffer("cart_add"), settings.smartDelay || 500);
      }

      return response;
    };

    const originalOpen = XMLHttpRequest.prototype.open;
    const originalSend = XMLHttpRequest.prototype.send;

    XMLHttpRequest.prototype.open = function(method, url, ...rest) {
      this.__areUrl = String(url || "");
      return originalOpen.call(this, method, url, ...rest);
    };

    XMLHttpRequest.prototype.send = function(body) {
      this.addEventListener("load", function() {
        if (isCartAddUrl(this.__areUrl || "")) {
          window.setTimeout(() => requestRevenueOffer("cart_add"), settings.smartDelay || 500);
        }
      });

      return originalSend.call(this, body);
    };

    document.addEventListener("submit", (event) => {
      const form = event.target;
      if (form?.tagName === "FORM" && isCartAddUrl(form.action || "")) {
        window.setTimeout(() => requestRevenueOffer("cart_form"), settings.smartDelay || 500);
      }
    }, true);
  }

  async function fetchCart() {
    const response = await fetch("/cart.js", {
      headers: { "Accept": "application/json" },
      cache: "no-store"
    });

    if (!response.ok) return null;
    return response.json();
  }

  function collectBehaviorContext(cart) {
    return {
      cartTotal: cart.total_price,
      itemCount: cart.item_count,
      currency: cart.currency,
      device: getDevice(),
      trafficSource: getTrafficSource(),
      referrer: document.referrer || "",
      pageType: getPageType(),
      path: window.location.pathname,
      viewportWidth: window.innerWidth,
      localHour: new Date().getHours(),
      viewedProducts: getViewedProducts()
    };
  }

  function buildTrackingPayload(offer, behaviorContext) {
    return {
      id: offer.id,
      title: offer.title,
      price: offer.price,
      image: offer.image,
      offerType: offer.offerType,
      mode: offer.mode,
      modeLabel: offer.modeLabel,
      placement: offer.placement,
      segment: offer.segment,
      insight: offer.insight,
      bundleId: offer.bundle?.id,
      bundleTitle: offer.bundle?.title,
      bundle: offer.bundle,
      experimentId: offer.experiment?.id,
      experimentVariant: offer.experiment?.variant,
      discount: offer.discount,
      behavior: behaviorContext || {}
    };
  }

  function trackEvent(eventName, data) {
    fetch("/apps/upsell/track", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        event: eventName,
        timestamp: new Date().toISOString(),
        data
      })
    }).catch(() => {});
  }

  function parseOffer(value) {
    if (!value) return null;
    if (typeof value === "object") return value;

    try {
      return JSON.parse(value);
    } catch (error) {
      const match = String(value).match(/\{[\s\S]*\}/);
      if (!match) return null;

      try {
        return JSON.parse(match[0]);
      } catch {
        return null;
      }
    }
  }

  function getOfferItems(offer) {
    if (offer.bundle?.items?.length) return offer.bundle.items;

    return [{
      id: offer.id,
      title: offer.title,
      price: offer.price,
      image: offer.image
    }];
  }

  function resolveRenderMode(placement) {
    const requested = settings.displayMode === "autopilot" ? placement : settings.displayMode;

    if (requested === "modal") return "modal";
    if (requested === "slide_cart") return "slide";
    if (requested === "both") return "inline";

    return "inline";
  }

  function hideOffer() {
    offerEl.hidden = true;
    backdropEl.hidden = true;
  }

  function setText(idPrefix, value) {
    const element = document.getElementById(`${idPrefix}-${blockId}`);
    if (element) element.textContent = value || "";
  }

  function toNumericVariantId(id) {
    const value = String(id || "");
    return value.includes("/") ? value.split("/").pop() : value;
  }

  function getCartSignature(cart) {
    return [
      cart.item_count,
      cart.total_price,
      ...(cart.items || []).map((item) => `${item.variant_id}:${item.quantity}`)
    ].join("|");
  }

  function getDevice() {
    if (window.innerWidth < 768) return "mobile";
    if (window.innerWidth < 1024) return "tablet";
    return "desktop";
  }

  function getPageType() {
    return window.ShopifyAnalytics?.meta?.page?.pageType || document.body.dataset.template || "unknown";
  }

  function getTrafficSource() {
    const params = new URLSearchParams(window.location.search);
    const utmSource = params.get("utm_source");
    if (utmSource) return utmSource;

    if (!document.referrer) return "direct";

    try {
      return new URL(document.referrer).hostname.replace(/^www\./, "");
    } catch {
      return "referral";
    }
  }

  function recordViewedProduct() {
    const product = window.ShopifyAnalytics?.meta?.product;
    if (!product) return;

    const views = getViewedProducts().filter((item) => String(item.id) !== String(product.id));
    views.unshift({
      id: product.id,
      title: product.title,
      handle: product.handle
    });

    localStorage.setItem("are_viewed_products", JSON.stringify(views.slice(0, 8)));
  }

  function getViewedProducts() {
    try {
      return JSON.parse(localStorage.getItem("are_viewed_products") || "[]");
    } catch {
      return [];
    }
  }

  function getRequestUrl(request) {
    if (typeof request === "string") return request;
    if (request?.url) return request.url;
    return "";
  }

  function isCartAddUrl(url) {
    return String(url || "").includes("/cart/add");
  }

  function escapeHtml(value) {
    return String(value || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }
})();
</script>

{% schema %}
{
  "name": "AI Revenue Engine",
  "target": "section",
  "class": "ai-revenue-engine-section",
  "settings": [
    {
      "type": "select",
      "id": "display_mode",
      "label": "Placement strategy",
      "options": [
        { "value": "autopilot", "label": "Autopilot" },
        { "value": "inline", "label": "Inline native block" },
        { "value": "slide_cart", "label": "Slide cart" },
        { "value": "modal", "label": "Modal fallback" }
      ],
      "default": "autopilot"
    },
    {
      "type": "range",
      "id": "smart_delay",
      "label": "Smart delay",
      "min": 0,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "trigger_on_load",
      "label": "Evaluate offer on page load",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "redirect_to_checkout",
      "label": "Go to checkout after offer is added",
      "default": false
    },
    {
      "type": "color",
      "id": "modal_background_color",
      "label": "Offer background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "image_section_Background_color",
      "label": "Media background",
      "default": "#f3f4f6"
    },
    {
      "type": "range",
      "id": "modal_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "color",
      "id": "modal_title_color",
      "label": "Title color",
      "default": "#111827"
    },
    {
      "type": "range",
      "id": "modal_title_fontSize",
      "label": "Title font size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "color",
      "id": "modal_price_color",
      "label": "Price color",
      "default": "#111827"
    },
    {
      "type": "range",
      "id": "modal_price_fontSize",
      "label": "Price font size",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "modal_text_color",
      "label": "Body text color",
      "default": "#374151"
    },
    {
      "type": "range",
      "id": "modal_text_fontSize",
      "label": "Body text size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "modal_button_color",
      "label": "Action color",
      "default": "#111827"
    },
