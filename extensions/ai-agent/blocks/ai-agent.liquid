<div
  id="ai-revenue-engine-{{ block.id }}"
  class="are-root"
  data-block-id="{{ block.id }}"
>
  <div id="are-backdrop-{{ block.id }}" class="are-backdrop" hidden></div>

  <section
    id="are-companion-{{ block.id }}"
    class="are-surface are-companion"
    aria-live="polite"
    hidden
  >
    <button type="button" class="are-close" data-are-close aria-label="Close recommendation">
      &times;
    </button>

    <div class="are-panel-glow" aria-hidden="true"></div>

    <div class="are-surface-head">
      <div class="are-title-stack">
        <span class="are-kicker">
          <span class="are-ai-mark" aria-hidden="true"></span>
          <span data-are-field="surfaceLabel">AI Product Companion</span>
        </span>
        <h3 class="are-title" data-are-field="title">Complete your setup</h3>
      </div>
      <span class="are-score" data-are-field="confidence">Live fit</span>
    </div>

    <div class="are-companion-layout">
      <div class="are-media" data-are-media></div>

      <div class="are-offer-copy">
        <p class="are-message" data-are-field="message"></p>

        <div class="are-context-row" data-are-context></div>

        <ul class="are-items" data-are-items></ul>
      </div>
    </div>

    <div class="are-journey" data-are-progress-wrap>
      <div class="are-journey-top">
        <span>Performance setup progress</span>
        <strong data-are-field="progressLabel">72%</strong>
      </div>
      <div class="are-progress-track" aria-hidden="true">
        <span data-are-progress-bar></span>
      </div>
      <p data-are-field="nextStep"></p>
    </div>

    <div class="are-reasoning" data-are-reasoning-wrap>
      <p data-are-field="insight"></p>
    </div>

    <div class="are-actions">
      <button type="button" class="are-submit" data-are-add>
        Add bundle
      </button>
      <span class="are-savings" data-are-field="savings"></span>
    </div>
  </section>

  <section
    id="are-progress-{{ block.id }}"
    class="are-surface are-progress-card"
    aria-live="polite"
    hidden
  >
    <div class="are-surface-head">
      <div class="are-title-stack">
        <span class="are-kicker">
          <span class="are-ai-mark" aria-hidden="true"></span>
          AI Progress Journey
        </span>
        <h3 class="are-title">Your setup is taking shape</h3>
      </div>
      <span class="are-score" data-are-field="confidence">Live fit</span>
    </div>

    <div class="are-journey are-journey-large">
      <div class="are-journey-top">
        <span>Commerce completion</span>
        <strong data-are-field="progressLabel">72%</strong>
      </div>
      <div class="are-progress-track" aria-hidden="true">
        <span data-are-progress-bar></span>
      </div>
      <p data-are-field="nextStep"></p>
    </div>

    <ul class="are-items are-items-compact" data-are-items></ul>

    <div class="are-reasoning" data-are-reasoning-wrap>
      <p data-are-field="insight"></p>
    </div>

    <div class="are-actions">
      <button type="button" class="are-submit" data-are-add>
        Add recommended products
      </button>
      <span class="are-savings" data-are-field="savings"></span>
    </div>
  </section>

  <section
    id="are-banner-{{ block.id }}"
    class="are-surface are-banner"
    aria-live="polite"
    hidden
  >
    <div class="are-banner-copy">
      <span class="are-kicker">
        <span class="are-ai-mark" aria-hidden="true"></span>
        AI Revenue Banner
      </span>
      <h3 class="are-title" data-are-field="title">Adaptive offer</h3>
      <p class="are-message" data-are-field="message"></p>
    </div>
    <div class="are-banner-side">
      <div class="are-mini-media" data-are-media></div>
      <button type="button" class="are-submit" data-are-add>
        Add offer
      </button>
    </div>
  </section>

  <aside
    id="are-drawer-{{ block.id }}"
    class="are-drawer"
    aria-live="polite"
    aria-label="AI cart intelligence"
    hidden
  >
    <div class="are-drawer-shell">
      <button type="button" class="are-close are-drawer-close" data-are-close aria-label="Close cart intelligence">
        &times;
      </button>

      <div class="are-drawer-head">
        <span class="are-kicker">
          <span class="are-ai-mark" aria-hidden="true"></span>
          AI Cart Intelligence
        </span>
        <h3 class="are-title">Your setup is almost complete</h3>
        <p class="are-message" data-are-field="message"></p>
      </div>

      <div class="are-journey">
        <div class="are-journey-top">
          <span>Setup progress</span>
          <strong data-are-field="progressLabel">72%</strong>
        </div>
        <div class="are-progress-track" aria-hidden="true">
          <span data-are-progress-bar></span>
        </div>
        <p data-are-field="nextStep"></p>
      </div>

      <div class="are-drawer-section">
        <div class="are-section-title">
          <span>Recommended for this cart</span>
          <strong data-are-field="savings"></strong>
        </div>
        <ul class="are-items are-drawer-items" data-are-items></ul>
      </div>

      <div class="are-reasoning" data-are-reasoning-wrap>
      <p data-are-field="insight"></p>
    </div>

      <button type="button" class="are-submit are-submit-large" data-are-add>
        Add all to cart
      </button>
    </div>
  </aside>

  <button
    type="button"
    id="are-orb-{{ block.id }}"
    class="are-orb"
    aria-label="Open AI shopping assistant"
    hidden
  >
    AI
  </button>

  <aside
    id="are-assistant-{{ block.id }}"
    class="are-assistant"
    aria-live="polite"
    aria-label="AI shopping assistant"
    hidden
  >
    <button type="button" class="are-close" data-are-close aria-label="Close assistant">
      &times;
    </button>
    <span class="are-kicker">
      <span class="are-ai-mark" aria-hidden="true"></span>
      Storefront Concierge
    </span>
    <h3 class="are-title" data-are-field="title">Complete your setup</h3>
    <div class="are-mini-media" data-are-media></div>
    <p class="are-message" data-are-field="message"></p>
    <div class="are-chat" aria-label="Shopping assistant chat">
      <div id="are-chat-messages-{{ block.id }}" class="are-chat-messages"></div>
      <div class="are-chat-compose">
        <input
          type="text"
          id="are-chat-input-{{ block.id }}"
          class="are-chat-input"
          placeholder="Ask me anything..."
        >
        <button type="button" id="are-chat-send-{{ block.id }}" class="are-chat-send">
          Send
        </button>
      </div>
    </div>
    <div class="are-reasoning" data-are-reasoning-wrap>
      <p data-are-field="insight"></p>
    </div>
    <button type="button" class="are-submit" data-are-add>
      Add recommendation
    </button>
  </aside>
</div>

