// Place this in a <script> tag or separate JS file loaded in your Shopify theme




  async function handleSubmit(event, form) {
    event.preventDefault(); 
    const btn = form.querySelector('.cb-add-to-cart-btn');
    const originalText = btn.innerHTML;
    const variantId = form.querySelector('input[name="id"]').value;
    const quantity = form.querySelector('input[name="quantity"]').value || 1;
    
    // Show loading
    btn.innerHTML = 'Adding...';
    btn.disabled = true;

    // Apply discount if exists
    if (currentDiscountCode) {
      try {
        // This sets the discount cookie in the browser
        await fetch(`/discount/${currentDiscountCode}`);
        console.log('Discount applied:', currentDiscountCode);
      } catch (err) {
        console.error('Failed to apply discount:', err);
      }
    }

    // Add to cart via AJAX
    try {
      if (!variantId) throw new Error('No variant ID provided');

      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          id: variantId,
          quantity: parseInt(quantity)
        })
      });

      if (!response.ok) {
        const errorText = await response.text();
        console.error('Cart add error response:', errorText);
        throw new Error('Failed to add to cart');
      }
      
      const cartData = await response.json();
      console.log('Item added to cart:', cartData);

      btn.innerHTML = 'Added!'; // Removed garbled characters
      
      // Optional: Refresh the page or redirect to checkout to see the discount
      // For now, let's just show the success state
      setTimeout(() => {
          btn.innerHTML = originalText;
          btn.disabled = false;
          closeChatbotModal(); // Close modal on success
          // window.location.href = '/checkout'; // Redirect removed
      }, 1000);

    } catch (err) {
      console.error('Cart add error:', err);
      btn.innerHTML = 'Error!';
      setTimeout(() => {
        btn.innerHTML = originalText;
        btn.disabled = false;
      }, 2000);
    }
}
