</style>

<script>
(() => {
  const blockId = "{{ block.id }}";
  const settings = {
    surface: "{{ block.settings.surface | default: 'adaptive_commerce' }}",
    displayMode: "{{ block.settings.display_mode | default: 'autopilot' }}",
    smartDelay: Number({{ block.settings.smart_delay | default: 1 }}) * 1000,
    triggerOnLoad: {{ block.settings.trigger_on_load | default: true | json }},
    redirectToCheckout: {{ block.settings.redirect_to_checkout | default: false | json }},
    assistantEnabled: {{ block.settings.assistant_enabled | default: true | json }},
    showReasoning: {{ block.settings.show_reasoning | default: true | json }},
    freeShippingThreshold: Number({{ block.settings.free_shipping_threshold | default: 100 }}),
    currency: "{{ shop.currency }}"
  };

  const root = document.getElementById(`ai-revenue-engine-${blockId}`);
  const companionEl = document.getElementById(`are-companion-${blockId}`);
  const progressEl = document.getElementById(`are-progress-${blockId}`);
  const bannerEl = document.getElementById(`are-banner-${blockId}`);
  const drawerEl = document.getElementById(`are-drawer-${blockId}`);
  const assistantEl = document.getElementById(`are-assistant-${blockId}`);
  const backdropEl = document.getElementById(`are-backdrop-${blockId}`);
  const orbEl = document.getElementById(`are-orb-${blockId}`);

  if (!root || window[`__are_${blockId}`]) return;
  window[`__are_${blockId}`] = true;

  const surfaces = {
    companion: companionEl,
    progress: progressEl,
    banner: bannerEl,
    drawer: drawerEl,
    assistant: assistantEl
  };

  let activeOffer = null;
  let activeBehavior = null;
  let activeCart = null;
  let activeSurface = null;
  let currentDiscountCode = null;
  let inFlight = false;
  let lastCartSignature = "";
  let isOrbOpen = false;
  
  // Behavioral tracking state
  let behaviorSignals = [];
  let dwellObserver = null;
  let lastScrollDepth = 0;
  let trackingFlushInterval = null;

  const visitorId = getOrCreateVisitorId();

  recordViewedProduct();
  installCartHooks();
  initBehaviorTracking();

  root.querySelectorAll("[data-are-close]").forEach((button) => {
    button.addEventListener("click", () => {
      hideSurfaces();
      if (activeOffer) {
        trackEvent("offer_dismissed", buildTrackingPayload(activeOffer, activeBehavior));
      }
    });
  });

  root.querySelectorAll("[data-are-add]").forEach((button) => {
    button.addEventListener("click", handleOfferAdd);
  });

  backdropEl?.addEventListener("click", hideSurfaces);
  orbEl?.addEventListener("click", handleAssistantToggle);

  if (settings.triggerOnLoad) {
    window.setTimeout(() => requestRevenueOffer("page_load"), settings.smartDelay);
  }

  // Always-on orb: show the floating chat button independently of upsell offers
  if (settings.assistantEnabled && orbEl) {
    window.setTimeout(() => {
      orbEl.hidden = false;
    }, settings.smartDelay);
  }

  async function handleAssistantToggle() {
    if (isOrbOpen) {
      hideSurfaces({ keepOrb: true });
      return;
    }

    if (!assistantEl) return;

    // Try to fetch an offer in the background if we don't have one yet
    if (!activeOffer) {
      requestRevenueOffer("assistant_open").catch(() => {});
    }

    hideSurfaces({ keepOrb: true });
    activeSurface = "assistant";

    // If we have an active offer, hydrate the assistant with it
    if (activeOffer) {
      hydrateSurface(assistantEl, activeOffer, activeBehavior, activeCart, "assistant");
    } else {
      // No offer yet — show a clean concierge panel
      setAll(assistantEl, "surfaceLabel", "Storefront Concierge");
      setAll(assistantEl, "title", "How can I help you?");
      setAll(assistantEl, "message", "");
      assistantEl.querySelectorAll("[data-are-media]").forEach(m => { m.innerHTML = ""; });
      assistantEl.querySelectorAll("[data-are-reasoning-wrap]").forEach(r => { r.hidden = true; });
      assistantEl.querySelectorAll("[data-are-add]").forEach(b => { b.hidden = true; });
    }

    assistantEl.hidden = false;
    setOrbOpen(true);

    if (!window[`__are_greeted_${blockId}`]) {
      window[`__are_greeted_${blockId}`] = true;
      addChatMessage("assistant", getGreetingMessage());
    }

    trackEvent("assistant_open", {
      ...buildTrackingPayload(activeOffer || {}, activeBehavior || {}),
      surface: "assistant"
    });

    document.getElementById(`are-chat-input-${blockId}`)?.focus();
  }

  function getGreetingMessage() {
    const pageType = getPageType();
    const viewed = getViewedProducts();

    if (pageType === "product" && viewed.length > 0) {
      return `Hi! I see you\'re checking out ${viewed[0].title || "this product"}. Want help finding the right match or a bundle deal?`;
    }
    if (viewed.length > 2) {
      return "Welcome back! You\'ve been browsing a few items — want me to find the best deal across what you\'ve seen?";
    }
    if (pageType === "collection") {
      return "Hi there! Looking for anything specific in this collection? I can help you find it.";
    }
    return "Hi! I\'m your shopping assistant. Ask me anything — product recommendations, order tracking, or questions about the store.";
  }

  async function requestRevenueOffer(trigger) {
    if (inFlight) return;
    inFlight = true;

    try {
      const cart = await fetchCart();
      if (!cart || !Array.isArray(cart.items)) return;

      const signature = getCartSignature(cart);
      if (!["page_load", "assistant_open"].includes(trigger) && signature === lastCartSignature) return;
      lastCartSignature = signature;

      if (cart.item_count === 0 && getPageType() !== "product") return;

      const behaviorContext = collectBehaviorContext(cart);
      const response = await fetch("/apps/upsell", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json"
        },
        body: JSON.stringify({
          cartItems: cart.items,
          cartTotal: normalizeCartTotal(cart),
          currency: cart.currency,
          itemCount: cart.item_count,
          behaviorContext,
          visitorId
        })
      });

      if (!response.ok) return;

      const data = await response.json();
      const offer = parseOffer(data.suggestion);
      if (!offer || !offer.id) return;

      activeOffer = offer;
      activeBehavior = behaviorContext;
      activeCart = cart;
      currentDiscountCode = offer.discount?.code || null;

      const surface = resolveSurface(trigger, offer, behaviorContext, cart);
      renderSurface(surface, offer, behaviorContext, cart, trigger);
    } catch (error) {
      console.warn("AI Revenue Engine skipped:", error);
    } finally {
      inFlight = false;
    }
  }

  function renderSurface(surface, offer, behaviorContext, cart, trigger) {
    const target = surfaces[surface] || companionEl;
    if (!target) return;

    activeSurface = surface;

    hideSurfaces({ keepOrb: true });
    hydrateSurface(target, offer, behaviorContext, cart, surface);

    if (surface === "drawer") {
      backdropEl.hidden = false;
    }

    target.hidden = false;

    if (settings.assistantEnabled || settings.surface === "floating_assistant") {
      orbEl.hidden = false;
    }

    setOrbOpen(surface === "assistant");

    trackEvent("upsell_impression", {
      ...buildTrackingPayload(offer, behaviorContext),
      surface,
      trigger
    });
  }

  function hydrateSurface(surfaceEl, offer, behaviorContext, cart, surface) {
    if (!surfaceEl) return;

    const items = getOfferItems(offer);
    const progress = calculateProgress(cart, items);
    const savings = getSavingsLabel(offer);
    const insight = getInsightText(offer, behaviorContext);

    setAll(surfaceEl, "surfaceLabel", getSurfaceLabel(surface));
    setAll(surfaceEl, "title", offer.bundle?.title || offer.title || "Complete your setup");
    setAll(surfaceEl, "message", offer.message || "A contextual recommendation selected for this cart.");
    surfaceEl.querySelectorAll(`[data-are-field="message"]`).forEach(el => {
      el.classList.remove("are-typewriter");
      void el.offsetWidth;
      el.classList.add("are-typewriter");
    });
    setAll(surfaceEl, "insight", insight);
    setAll(surfaceEl, "confidence", getConfidenceLabel(offer));
    setAll(surfaceEl, "progressLabel", `${progress.value}%`);
    setAll(surfaceEl, "nextStep", progress.nextStep);
    setAll(surfaceEl, "savings", savings);

    surfaceEl.querySelectorAll("[data-are-progress-bar]").forEach((bar) => {
      bar.style.width = `${progress.value}%`;
    });

    surfaceEl.querySelectorAll("[data-are-reasoning-wrap]").forEach((element) => {
      element.hidden = !settings.showReasoning || !insight;
    });

    surfaceEl.querySelectorAll("[data-are-add]").forEach((button) => {
      button.textContent = getButtonLabel(offer);
      button.disabled = false;
    });

    surfaceEl.querySelectorAll("[data-are-media]").forEach((media) => renderMedia(media, items));
    surfaceEl.querySelectorAll("[data-are-items]").forEach((list) => {
      renderItems(list, items, offer, behaviorContext, surface);
    });
    surfaceEl.querySelectorAll("[data-are-context]").forEach((row) => {
      renderContext(row, offer, behaviorContext);
    });
  }

  function renderMedia(media, items) {
    media.classList.toggle("are-single", items.length <= 1);
    media.innerHTML = items
      .slice(0, 4)
      .map((item) => {
        const image = escapeHtml(item.image || "");
        const title = escapeHtml(item.title || "Recommended product");
        return `<img src="${image}" alt="${title}" loading="lazy">`;
      })
      .join("");
  }

  function renderItems(list, items, offer, behaviorContext, surface) {
    const compact = surface === "progress";
    list.innerHTML = items
      .map((item, index) => {
        const title = escapeHtml(item.title || "Recommended product");
        const price = escapeHtml(item.price || "");
        const reason = escapeHtml(getItemReason(item, index, offer, behaviorContext));
        const image = escapeHtml(item.image || "");

        const discountPct = offer.discount?.percentage || 0;
        let priceHtml = `<strong class="are-item-price">${price}</strong>`;
        
        if (discountPct > 0) {
            // Rough calculation for display purposes
            const numericPrice = parseFloat(price.replace(/[^0-9.]/g, ''));
            if (!isNaN(numericPrice)) {
                const original = (numericPrice / (1 - (discountPct / 100))).toFixed(2);
                const currencySymbol = price.replace(/[0-9.,]/g, '');
                priceHtml = `
                    <strong class="are-item-price">
                        <span class="are-item-price-original">${currencySymbol}${original}</span>
                        <span class="are-item-price-discounted">${price}</span>
                    </strong>
                `;
            }
        }

        if (compact) {
          return `
            <li class="are-item">
              <span class="are-item-main">
                <span class="are-item-title">${title}</span>
                <span class="are-item-reason">${reason}</span>
              </span>
              ${priceHtml}
            </li>
          `;
        }

        return `
          <li class="are-item">
            <img class="are-item-image" src="${image}" alt="${title}" loading="lazy">
            <span class="are-item-main">
              <span class="are-item-title">${title}</span>
              <span class="are-item-reason">${reason}</span>
            </span>
            ${priceHtml}
          </li>
        `;
      })
      .join("");
  }

  function renderContext(row, offer, behaviorContext) {
    const viewedCount = behaviorContext.viewedProducts?.length || 0;
    const chips = [
      offer.modeLabel || "Revenue mode",
      formatPlacement(offer.placement || activeSurface),
      viewedCount ? `${viewedCount} product signals` : "Live cart signal",
      formatDevice(behaviorContext.device)
    ].filter(Boolean);

    row.innerHTML = chips
      .slice(0, 4)
      .map((chip) => `<span class="are-chip">${escapeHtml(chip)}</span>`)
      .join("");
  }

  async function handleOfferAdd(event) {
    event.preventDefault();
    if (!activeOffer) return;

    const buttons = Array.from(root.querySelectorAll("[data-are-add]"));
    const originalLabels = buttons.map((button) => button.textContent);
    buttons.forEach((button) => {
      button.disabled = true;
      button.textContent = "Adding...";
    });

    try {
      if (currentDiscountCode) {
        await fetch(`/discount/${encodeURIComponent(currentDiscountCode)}`);
      }

      const items = getOfferItems(activeOffer).map((item) => ({
        id: toNumericVariantId(item.id),
        quantity: 1
      }));

      const response = await fetch("/cart/add.js", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json"
        },
        body: JSON.stringify(items.length > 1 ? { items } : items[0])
      });

      if (!response.ok) throw new Error("Unable to add offer to cart");

      const cartResponse = await response.json();
      trackEvent("upsell_add_to_cart", {
        ...buildTrackingPayload(activeOffer, activeBehavior),
        surface: activeSurface,
        cartResponse
      });

      buttons.forEach((button) => {
        button.textContent = "Added";
      });

      window.setTimeout(() => {
        buttons.forEach((button, index) => {
          button.disabled = false;
          button.textContent = originalLabels[index] || getButtonLabel(activeOffer);
        });
        hideSurfaces({ keepOrb: true });

        if (settings.redirectToCheckout) {
          window.location.href = "/checkout";
        }
      }, 850);
    } catch (error) {
      console.warn("Offer add failed:", error);
      buttons.forEach((button) => {
        button.textContent = "Try again";
      });
      window.setTimeout(() => {
        buttons.forEach((button, index) => {
          button.disabled = false;
          button.textContent = originalLabels[index] || getButtonLabel(activeOffer);
        });
      }, 1300);
    }
  }

  function installCartHooks() {
    const originalFetch = window.fetch;

    window.fetch = async function(...args) {
      const response = await originalFetch.apply(this, args);
      const url = getRequestUrl(args[0]);

      if (isCartAddUrl(url) && !url.includes("/apps/upsell")) {
        trackBehavioralSignal("cart_add", getCartAddSignal(url, args[1]?.body));
        window.setTimeout(async () => {
          await flushBehavioralSignals();
          requestRevenueOffer("cart_add");
        }, settings.smartDelay || 500);
      }
      
      if (isCartChangeUrl(url) && isCartRemoveReq(args)) {
         trackBehavioralSignal("cart_remove", { url });
      }

      return response;
    };

    const originalOpen = XMLHttpRequest.prototype.open;
    const originalSend = XMLHttpRequest.prototype.send;

    XMLHttpRequest.prototype.open = function(method, url, ...rest) {
      this.__areUrl = String(url || "");
      return originalOpen.call(this, method, url, ...rest);
    };

    XMLHttpRequest.prototype.send = function(body) {
      this.addEventListener("load", function() {
        if (isCartAddUrl(this.__areUrl || "")) {
          trackBehavioralSignal("cart_add", getCartAddSignal(this.__areUrl || "", body));
          window.setTimeout(async () => {
            await flushBehavioralSignals();
            requestRevenueOffer("cart_add");
          }, settings.smartDelay || 500);
        }
      });

      return originalSend.call(this, body);
    };

    document.addEventListener("submit", (event) => {
      const form = event.target;
      if (form?.tagName === "FORM" && isCartAddUrl(form.action || "")) {
        trackBehavioralSignal("cart_add", getCartAddSignal(form.action || "", new FormData(form)));
        window.setTimeout(async () => {
          await flushBehavioralSignals();
          requestRevenueOffer("cart_form");
        }, settings.smartDelay || 500);
      }
    }, true);
  }

  async function fetchCart() {
    const response = await fetch("/cart.js", {
      headers: { "Accept": "application/json" },
      cache: "no-store"
    });

    if (!response.ok) return null;
    return response.json();
  }

  function collectBehaviorContext(cart) {
    return {
      cartTotal: normalizeCartTotal(cart),
      itemCount: cart.item_count,
      currency: cart.currency,
      device: getDevice(),
      trafficSource: getTrafficSource(),
      referrer: document.referrer || "",
      pageType: getPageType(),
      path: window.location.pathname,
      viewportWidth: window.innerWidth,
      localHour: new Date().getHours(),
      viewedProducts: getViewedProducts()
    };
  }

  function resolveSurface(trigger, offer, behaviorContext, cart) {
    if (settings.surface === "product_companion") return "companion";
    if (settings.surface === "cart_intelligence") return "drawer";
    if (settings.surface === "progress_journey") return "progress";
    if (settings.surface === "revenue_banner") return "banner";
    if (settings.surface === "floating_assistant") return "assistant";

    if (settings.displayMode === "slide_cart") return "drawer";
    if (settings.displayMode === "inline") return "companion";
    if (settings.displayMode === "both") return "companion";

    const placement = String(offer.placement || "").toLowerCase();
    const pageType = String(behaviorContext.pageType || "").toLowerCase();

    if (["cart_add", "cart_form"].includes(trigger)) return "drawer";
    if (placement.includes("cart") || pageType.includes("cart")) return "drawer";
    if (settings.displayMode === "modal") return "drawer";
    if (settings.displayMode === "modal_fallback") return "drawer";
    if (placement.includes("checkout")) return "progress";
    if (placement.includes("product") || pageType.includes("product")) return "companion";
    if (cart.item_count > 0) return "progress";

    return "banner";
  }

  function hideSurfaces(options = {}) {
    Object.values(surfaces).forEach((surface) => {
      if (surface) surface.hidden = true;
    });
    backdropEl.hidden = true;
    setOrbOpen(false);

    if (!options.keepOrb && orbEl) {
      orbEl.hidden = true;
    }
  }

  function setOrbOpen(open) {
    isOrbOpen = Boolean(open);
    if (orbEl) {
      orbEl.classList.toggle("open", isOrbOpen);
      orbEl.setAttribute("aria-expanded", String(isOrbOpen));
    }
  }

  function setAll(scope, field, value) {
    scope.querySelectorAll(`[data-are-field="${field}"]`).forEach((element) => {
      element.textContent = value || "";
    });
  }

  function getOfferItems(offer) {
    if (offer.bundle?.items?.length) return offer.bundle.items;

    return [{
      id: offer.id,
      title: offer.title,
      price: offer.price,
      image: offer.image
    }];
  }

  function calculateProgress(cart, items) {
    const itemCount = Number(cart.item_count || 0);
    const cartTotal = normalizeCartTotal(cart);
    const signalBoost = Math.min(items.length, 3) * 6;
    const valueBoost = cartTotal >= 150 ? 14 : cartTotal >= 75 ? 9 : cartTotal >= 30 ? 5 : 0;
    const value = clamp(36 + Math.min(itemCount, 4) * 10 + signalBoost + valueBoost, 42, 92);
    const shippingText = getShippingText(cartTotal);
    const lead = items[0]?.title || "the next recommended item";

    return {
      value,
      nextStep: shippingText || `Add ${lead} to complete the next step.`
    };
  }

  function getShippingText(cartTotal) {
    const threshold = settings.freeShippingThreshold;
    if (!threshold || threshold <= 0) return "";

    const remaining = threshold - cartTotal;
    if (remaining <= 0) return "Free shipping is unlocked for this cart.";

    return `Add ${formatMoney(remaining, settings.currency)} more to unlock free shipping.`;
  }

  function getSavingsLabel(offer) {
    const percent = offer.discount?.percentage || offer.bundle?.discountPercentage;
    if (percent) return `Save ${percent}%`;
    if (offer.bundle?.subtotal && offer.bundle?.discountedTotal && offer.bundle.subtotal !== offer.bundle.discountedTotal) {
      return `${offer.bundle.discountedTotal} bundle`;
    }
    return offer.offerType === "bundle" ? "Bundle ready" : "High-fit add-on";
  }

  function getButtonLabel(offer) {
    const savings = offer.discount?.percentage || offer.bundle?.discountPercentage;
    if (offer.offerType === "bundle") {
      return savings ? `Add bundle and save ${savings}%` : "Add bundle to cart";
    }
    return savings ? `Add recommendation and save ${savings}%` : "Add recommendation";
  }

  function getConfidenceLabel(offer) {
    if (offer.confidence) return `${offer.confidence}% match`;
    return "Live fit";
  }

  function getSurfaceLabel(surface) {
    if (surface === "drawer") return "AI Cart Intelligence";
    if (surface === "progress") return "AI Progress Journey";
    if (surface === "banner") return "AI Revenue Banner";
    if (surface === "assistant") return "Storefront Concierge";
    return "AI Product Companion";
  }

  function getInsightText(offer, behaviorContext) {
    return offer.insight || offer.reasoning || offer.autopilotAction || `Selected from ${behaviorContext.trafficSource || "live"} session signals.`;
  }

  function getItemReason(item, index, offer, behaviorContext) {
    const reasons = offer.metadata?.scoreReasons || [];
    if (reasons[index]) return cleanReason(reasons[index]);

    const pageType = String(behaviorContext.pageType || "").toLowerCase();
    if (index === 0 && offer.offerType === "bundle") return "Anchors the recommended setup.";
    if (pageType.includes("product")) return "Matches the product being viewed.";
    if (behaviorContext.viewedProducts?.length) return "Uses recent browsing signals.";
    if (index === 1) return "Frequently paired before checkout.";
    return "Selected for current cart intent.";
  }

  function cleanReason(value) {
    return String(value || "")
      .replace(/\.$/, "")
      .replace(/^Matched /, "Matched ")
      .replace(/^Fits /, "Fits ");
  }

  function formatPlacement(value) {
    const placement = String(value || "").replace(/_/g, " ");
    if (!placement) return "";
    return placement.charAt(0).toUpperCase() + placement.slice(1);
  }

  function formatDevice(value) {
    if (!value) return "";
    const device = String(value);
    return device.charAt(0).toUpperCase() + device.slice(1);
  }

  function normalizeCartTotal(cart) {
    const total = Number(cart.total_price || 0);
    return total / 100;
  }

  function buildTrackingPayload(offer, behaviorContext) {
    return {
      id: offer.id,
      title: offer.title,
      price: offer.price,
      image: offer.image,
      offerType: offer.offerType,
      mode: offer.mode,
      modeLabel: offer.modeLabel,
      placement: offer.placement,
      segment: offer.segment,
      insight: offer.insight,
      bundleId: offer.bundle?.id,
      bundleTitle: offer.bundle?.title,
      bundle: offer.bundle,
      experimentId: offer.experiment?.id,
      experimentVariant: offer.experiment?.variant,
      discount: offer.discount,
      behavior: behaviorContext || {}
    };
  }

  function trackEvent(eventName, data) {
    fetch("/apps/upsell/track", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        event: eventName,
        timestamp: new Date().toISOString(),
        data
      })
    }).catch(() => {});
  }

  function parseOffer(value) {
    if (!value) return null;
    if (typeof value === "object") return value;

    try {
      return JSON.parse(value);
    } catch (error) {
      const match = String(value).match(/\{[\s\S]*\}/);
      if (!match) return null;

      try {
        return JSON.parse(match[0]);
      } catch {
        return null;
      }
    }
  }

  function toNumericVariantId(id) {
    const value = String(id || "");
    return value.includes("/") ? value.split("/").pop() : value;
  }

  function getCartSignature(cart) {
    return [
      cart.item_count,
      cart.total_price,
      ...(cart.items || []).map((item) => `${item.variant_id}:${item.quantity}`)
    ].join("|");
  }

  function getDevice() {
    if (window.innerWidth < 768) return "mobile";
    if (window.innerWidth < 1024) return "tablet";
    return "desktop";
  }

  function getPageType() {
    return window.ShopifyAnalytics?.meta?.page?.pageType || document.body.dataset.template || "unknown";
  }

  function getTrafficSource() {
    const params = new URLSearchParams(window.location.search);
    const utmSource = params.get("utm_source");
    if (utmSource) return utmSource;

    if (!document.referrer) return "direct";

    try {
      return new URL(document.referrer).hostname.replace(/^www\./, "");
    } catch {
      return "referral";
    }
  }

  function recordViewedProduct() {
    const product = window.ShopifyAnalytics?.meta?.product;
    if (!product) return;

    const views = getViewedProducts().filter((item) => String(item.id) !== String(product.id));
    views.unshift({
      id: product.id,
      title: product.title,
      handle: product.handle
    });

    localStorage.setItem("are_viewed_products", JSON.stringify(views.slice(0, 8)));
  }

  function getViewedProducts() {
    try {
      return JSON.parse(localStorage.getItem("are_viewed_products") || "[]");
    } catch {
      return [];
    }
  }

  function getRequestUrl(request) {
    if (typeof request === "string") return request;
    if (request?.url) return request.url;
    return "";
  }

  function isCartAddUrl(url) {
    return String(url || "").includes("/cart/add");
  }

  function isCartChangeUrl(url) {
    return String(url || "").includes("/cart/change") || String(url || "").includes("/cart/update");
  }

  function getCartAddSignal(url, body) {
    const signal = { url: String(url || "") };
    const variantId = getVariantIdFromBody(body);
    if (variantId) signal.variantId = variantId;
    return signal;
  }

  function getVariantIdFromBody(body) {
    try {
      if (!body) return "";

      if (typeof FormData !== "undefined" && body instanceof FormData) {
        return String(body.get("id") || body.get("items[0][id]") || "");
      }

      if (typeof URLSearchParams !== "undefined" && body instanceof URLSearchParams) {
        return String(body.get("id") || body.get("items[0][id]") || "");
      }

      if (typeof body === "object" && "id" in body) {
        return String(body.id || "");
      }

      const bodyText = String(body || "");
      if (!bodyText) return "";

      if (bodyText.trim().startsWith("{")) {
        const parsed = JSON.parse(bodyText);
        return String(parsed.id || parsed.items?.[0]?.id || "");
      }

      const params = new URLSearchParams(bodyText);
      return String(params.get("id") || params.get("items[0][id]") || "");
    } catch {
      return "";
    }
  }

  function isCartRemoveReq(args) {
    try {
      if (args.length > 1 && args[1] && args[1].body) {
        const bodyStr = String(args[1].body);
        if (bodyStr.includes("quantity=0") || bodyStr.includes('"quantity":0') || bodyStr.includes('"quantity": 0')) {
           return true;
        }
      }
      return false;
    } catch {
      return false;
    }
  }

  function getOrCreateVisitorId() {
    let vid = localStorage.getItem("are_visitor_id");
    if (!vid) {
      vid = 'vid_' + Math.random().toString(36).substring(2, 15) + Math.random().toString(36).substring(2, 15);
      localStorage.setItem("are_visitor_id", vid);
    }
    return vid;
  }

  function trackBehavioralSignal(type, data) {
    behaviorSignals.push({
      type,
      data,
      timestamp: new Date().toISOString()
    });
  }

  async function flushBehavioralSignals() {
    if (behaviorSignals.length === 0) return;
    
    const signalsToSend = [...behaviorSignals];
    behaviorSignals = [];

    try {
      await fetch("/apps/upsell/behavior", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        keepalive: true,
        body: JSON.stringify({
          visitorId,
          signals: signalsToSend,
          storeId: window.Shopify?.shop || "{{ shop.domain }}"
        })
      });
    } catch (e) {
      behaviorSignals = [...signalsToSend, ...behaviorSignals];
    }
  }

  function initBehaviorTracking() {
    trackBehavioralSignal("page_view", {
      path: window.location.pathname,
      device: getDevice(),
      trafficSource: getTrafficSource(),
      referrer: document.referrer || ""
    });

    const product = window.ShopifyAnalytics?.meta?.product;
    if (product) {
      trackBehavioralSignal("product_view", { id: product.id, title: product.title });
      
      let dwellStart = Date.now();
      const reportDwell = () => {
         const durationMs = Date.now() - dwellStart;
         if (durationMs > 2000) {
            trackBehavioralSignal("dwell", { productId: product.id, durationMs });
         }
         dwellStart = Date.now();
      };

      setInterval(reportDwell, 15000);

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) reportDwell();
        else dwellStart = Date.now();
      });
    }

    let scrollTimeout;
    window.addEventListener("scroll", () => {
      if (scrollTimeout) return;
      scrollTimeout = setTimeout(() => {
        const scrollPercent = Math.round((window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100);
        if (scrollPercent > lastScrollDepth + 10) {
          lastScrollDepth = scrollPercent;
          trackBehavioralSignal("scroll_depth", { path: window.location.pathname, depth: scrollPercent });
        }
        scrollTimeout = null;
      }, 500);
    }, { passive: true });

    if (getDevice() === "desktop") {
      document.documentElement.addEventListener("mouseleave", (e) => {
        if (e.clientY <= 0) {
          trackBehavioralSignal("exit_intent", { path: window.location.pathname });
          flushBehavioralSignals();
        }
      });
    }

    trackingFlushInterval = setInterval(flushBehavioralSignals, 5000);
    window.addEventListener("pagehide", flushBehavioralSignals);
    window.addEventListener("beforeunload", flushBehavioralSignals);
    
    const chatInput = document.getElementById(`are-chat-input-${blockId}`);
    const chatSend = document.getElementById(`are-chat-send-${blockId}`);
    
    if (chatInput && chatSend) {
      const sendHandler = async () => {
        const text = chatInput.value.trim();
        if (!text) return;
        
        chatInput.value = "";
        chatInput.disabled = true;
        chatSend.disabled = true;
        
        addChatMessage("user", text);
        
        try {
          const res = await fetch("/apps/upsell/chat", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              visitorId,
              message: text,
              storeId: window.Shopify?.shop || "{{ shop.domain }}",
              context: { cartTotal: activeCart ? normalizeCartTotal(activeCart) : 0 }
            })
          });
          
          if (res.ok) {
            const data = await res.json();
            if (data.reply) {
              addChatMessage("assistant", data.reply);
            }
            if (data.products && Array.isArray(data.products)) {
              data.products.forEach(p => addProductCard(p));
            }
          } else {
            addChatMessage("assistant", "Sorry, I had trouble connecting.");
          }
        } catch (e) {
          addChatMessage("assistant", "Sorry, I had a network error.");
        } finally {
          chatInput.disabled = false;
          chatSend.disabled = false;
          chatInput.focus();
        }
      };
      
      chatSend.addEventListener("click", sendHandler);
      chatInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter") sendHandler();
      });
    }
  }
  
  function addChatMessage(role, text) {
    const messagesEl = document.getElementById(`are-chat-messages-${blockId}`);
    if (!messagesEl) return;
    
    const msgEl = document.createElement("div");
    msgEl.className = `are-chat-message are-chat-message-${role === "user" ? "user" : "assistant"}`;
    
    msgEl.textContent = text;
    messagesEl.appendChild(msgEl);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function addProductCard(product) {
    const messagesEl = document.getElementById(`are-chat-messages-${blockId}`);
    if (!messagesEl || !product) return;

    const cardEl = document.createElement("div");
    cardEl.className = "are-chat-product-card";

    const imgSrc = escapeHtml(product.image || "");
    const title = escapeHtml(product.title || "Recommended product");
    const price = escapeHtml(product.price ? `$${product.price}` : "");
    const variantId = product.variantId || product.id || "";
    const numericId = String(variantId).includes("/") ? String(variantId).split("/").pop() : String(variantId);
    const handle = escapeHtml(product.handle || "");

    cardEl.innerHTML = `
      <img src="${imgSrc}" alt="${title}" loading="lazy">
      <div class="are-chat-product-info">
        <span class="are-chat-product-title">${title}</span>
        <span class="are-chat-product-price">${price}</span>
        <button type="button" class="are-chat-product-add" data-variant-id="${escapeHtml(numericId)}" data-handle="${handle}">
          Add to Cart
        </button>
      </div>
    `;

    const addBtn = cardEl.querySelector(".are-chat-product-add");
    if (addBtn) {
      addBtn.addEventListener("click", async function() {
        const btn = this;
        const vid = btn.getAttribute("data-variant-id");
        if (!vid) return;

        btn.disabled = true;
        btn.textContent = "Adding...";

        try {
          const resp = await fetch("/cart/add.js", {
            method: "POST",
            headers: { "Content-Type": "application/json", "Accept": "application/json" },
            body: JSON.stringify({ id: vid, quantity: 1 })
          });

          if (resp.ok) {
            btn.textContent = "Added ✓";
            trackEvent("chat_product_add", { variantId: vid, title, source: "chat_card" });
          } else {
            btn.textContent = "Failed";
            window.setTimeout(() => { btn.textContent = "Add to Cart"; btn.disabled = false; }, 1500);
          }
        } catch (err) {
          btn.textContent = "Failed";
          window.setTimeout(() => { btn.textContent = "Add to Cart"; btn.disabled = false; }, 1500);
        }
      });
    }

    messagesEl.appendChild(cardEl);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function formatMoney(value, currency) {
    try {
      return new Intl.NumberFormat(undefined, {
        style: "currency",
        currency: currency || settings.currency || "USD"
      }).format(value);
    } catch {
      return `${Number(value || 0).toFixed(2)}`;
    }
  }

  function clamp(value, min, max) {
    return Math.min(Math.max(Math.round(value), min), max);
  }

  function escapeHtml(value) {
    return String(value || "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }
})();
</script>

