// Enhanced cart polling with retry logic
async function pollCart() {
  const maxRetries = 3;
  let retryCount = 0;
  
  while (retryCount < maxRetries) {
    try {
      await fetchUpsellSuggestion();
      break; // Success, exit retry loop
    } catch (error) {
      retryCount++;
    //  console.warn(`Upsell attempt ${retryCount} failed:`, error.message);
      
      if (retryCount < maxRetries) {
        // Wait before retrying (exponential backoff)
        const delay = Math.pow(2, retryCount) * 1000;
    //    console.log(`Retrying in ${delay}ms...`);
        await new Promise(resolve => setTimeout(resolve, delay));
      } else {
    //    console.error('All upsell attempts failed');
      }
    }
  }
}

// Alternative: Check if endpoint exists before calling
async function checkUpsellEndpoint() {
  try {
    const response = await fetch('/apps/upsell', {
      method: 'OPTIONS' // Pre-flight check
    });
    return response.ok;
  } catch (error) {
  //  console.warn('Upsell endpoint check failed:', error);
    return false;
  }
}









function showUpsellDisplay(message, cart) {
  const displayMode = "{{ block.settings.display_mode | default: 'modal' }}";
  const smartDelay = {{ block.settings.smart_delay | default: 2 }} * 1000;
  
  // Logic to determine which display to show
  const showModal = () => {
    const modal = document.getElementById('chatbot-messages');
    const titleEl = document.getElementById('chatbot-title');
    const imageEl = document.getElementById('chatbot-image');
    const priceEl = document.getElementById('chatbot-price');
    const priceCurrency = document.getElementById('chatbot-currency');
    const textEl = document.getElementById('chatbot-text');
    const variantInput = document.getElementById('upsell-variant-id');

    if (titleEl) titleEl.textContent = message.title || '';
    if (priceEl) priceEl.textContent = message.price;
    if (priceCurrency) priceCurrency.textContent = cart.currency;
    if (textEl) textEl.textContent = message.message || '';
    if (imageEl) imageEl.src = message.image;
    
    // Handle Gamification Message
    const gamificationBadge = document.getElementById('cb-gamification-msg');
    if (gamificationBadge) {
      if (message.gamification) {
        gamificationBadge.textContent = message.gamification;
        gamificationBadge.style.display = 'inline-block';
      } else {
        gamificationBadge.style.display = 'none';
      }
    }

    // Handle Discount
    const discountBadge = document.getElementById('cb-discount-badge');
    currentDiscountCode = null; // Reset
    if (discountBadge) {
      if (message.discount && message.discount.percentage) {
        discountBadge.textContent = `🔥 SPECIAL: ${message.discount.percentage}% OFF`;
        discountBadge.style.display = 'inline-block';
        currentDiscountCode = message.discount.code || 'SMART-AI-REWARD';
      } else {
        discountBadge.style.display = 'none';
      }
    }
    
    if (variantInput && message.id) {
       const gid = message.id;
       const numericId = gid.includes('/') ? gid.split("/").pop() : gid;
       variantInput.value = numericId;
    }

    const popupPos = "{{ block.settings.popup_position }}";
    if (popupPos === 'center') {
      document.getElementById('chatbot-backdrop').style.display = 'block';
    }
    document.getElementById('chatbot-messages').style.display = 'block';
  };

  const showInline = () => {
    const inlineContainer = document.getElementById('cb-inline-display');
    const titleEl = document.getElementById('cb-inline-title');
    const imageEl = document.getElementById('cb-inline-image');
    const priceEl = document.getElementById('cb-inline-price');
    const priceCurrency = document.getElementById('cb-inline-currency');
    const textEl = document.getElementById('cb-inline-text');
    const variantInput = document.getElementById('cb-inline-variant-id');

    if (titleEl) titleEl.textContent = message.title || '';
    if (priceEl) priceEl.textContent = message.price;
    if (priceCurrency) priceCurrency.textContent = cart.currency;
    if (textEl) textEl.textContent = message.message || '';
    if (imageEl) imageEl.src = message.image;

    // Handle Inline Gamification Message
    const inlineGamificationBadge = document.getElementById('cb-inline-gamification-msg');
    if (inlineGamificationBadge) {
      if (message.gamification) {
        inlineGamificationBadge.textContent = message.gamification;
        inlineGamificationBadge.style.display = 'inline-block';
      } else {
        inlineGamificationBadge.style.display = 'none';
      }
    }
    
    // Handle Discount
    const inlineDiscountBadge = document.getElementById('cb-inline-discount-badge');
    if (inlineDiscountBadge) {
      if (message.discount && message.discount.percentage) {
        inlineDiscountBadge.textContent = `🔥 SAVE ${message.discount.percentage}% NOW`;
        inlineDiscountBadge.style.display = 'inline-block';
        currentDiscountCode = message.discount.code || 'SMART-AI-REWARD';
      } else {
        inlineDiscountBadge.style.display = 'none';
      }
    }

    if (variantInput && message.id) {
       const gid = message.id;
       const numericId = gid.includes('/') ? gid.split("/").pop() : gid;
       variantInput.value = numericId;
    }

    if (inlineContainer) inlineContainer.style.display = 'block';
  };

  // Apply Smart Delay
  setTimeout(() => {
    if (displayMode === 'modal') {
      showModal();
    } else if (displayMode === 'inline') {
      showInline();
    } else { // 'both'
      // Show inline first, if it's already there, maybe skip modal? 
      // For now, let's just show both if both are configured
      showInline();
      // Optional: Wait more for modal?
    }
  }, smartDelay);
}



