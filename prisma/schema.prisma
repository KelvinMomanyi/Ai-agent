// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ShopConfig {
  shopDomain                  String   @id
  discountPercentage          Int      @default(10)
  offerStrategy               String   @default("Focus on high-value complementary items with a gentle discount sweetener.")
  brandVoice                  String?  @default("")
  minProductPrice             Float    @default(20.0)
  revenueMode                 String   @default("aov")
  enableAutopilot             Boolean  @default(true)
  enableDynamicBundles        Boolean  @default(true)
  enableExperimentation       Boolean  @default(true)
  enableBehavioralTargeting   Boolean  @default(true)
  primaryPlacement            String   @default("inline")
  maxBundleItems              Int      @default(3)
  urgencyLevel                String   @default("balanced")
  updatedAt                   DateTime @updatedAt
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean?
  locale        String?
  collaborator  Boolean?


  emailVerified Boolean?

  @@map("session")
}

model Shop {
  shopDomain     String   @id
  accessToken    String
  scope          String?
  installedAt    DateTime @default(now())
  productCatalog Json?
}

// In Prisma schema
model Event {
  id        String   @id @default(cuid())
  event     String
  orderId   String?  // Add this field
  storeId   String
  timestamp DateTime
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Add this unique constraint
  @@unique([event, orderId, storeId], name: "event_orderId_storeId")
}

model VisitorSession {
  id              String   @id @default(cuid())
  visitorId       String   // fingerprint or cookie-based anonymous ID
  storeId         String
  sessionStart    DateTime @default(now())
  lastActivity    DateTime @default(now())
  device          String?
  trafficSource   String?
  referrer        String?

  // Intent signals (updated incrementally)
  viewedProducts  Json     @default("[]")    // [{id, title, viewCount, dwellMs}]
  cartAdds        Json     @default("[]")    // [{variantId, timestamp}]
  cartRemoves     Json     @default("[]")    // [{variantId, timestamp}]
  scrollDepths    Json     @default("{}")    // {"/products/x": 82}
  pageViews       Int      @default(0)
  totalDwellMs    Int      @default(0)

  // Computed intent classification
  intentProfile   String   @default("browsing") // browsing | considering | high_intent | price_sensitive | abandoning
  intentScore     Float    @default(0)

  @@index([storeId, visitorId])
  @@index([storeId, lastActivity])
}

model ChatMessage {
  id          String   @id @default(cuid())
  sessionId   String   // links to VisitorSession.id
  storeId     String
  role        String   // "assistant" | "user" | "system"
  content     String
  metadata    Json?    // {action: "offer_surfaced", offerId: "...", discountApplied: true}
  timestamp   DateTime @default(now())

  @@index([sessionId, timestamp])
}

model CrossStoreInsight {
  id          String   @id @default(cuid())
  category    String   // e.g. "Athletic Shoes"
  metricName  String   // e.g. "price_elasticity", "add_to_cart_rate"
  value       Float
  confidence  Float
  updatedAt   DateTime @updatedAt
  
  @@unique([category, metricName])
}
