// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ShopConfig {
  shopDomain         String @id
  discountPercentage Int    @default(10)
  offerStrategy      String @default("Focus on high-value complementary items with a gentle discount sweetener.")
  minProductPrice    Float  @default(20.0)
  updatedAt          DateTime @updatedAt
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean?
  locale        String?
  collaborator  Boolean?
  emailVerified Boolean?

  @@map("session")
}


model Shop {
  shopDomain     String   @id
  accessToken    String
  scope          String?
  installedAt    DateTime @default(now())
  productCatalog Json?
}

// In Prisma schema
model Event {
  id        String   @id @default(cuid())
  event     String
  orderId   String?  // Add this field
  storeId   String
  timestamp DateTime
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Add this unique constraint
  @@unique([event, orderId, storeId], name: "event_orderId_storeId")
}



